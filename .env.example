
# ============================================
#   MARCO MALIK MD - Environment Variables
# ============================================

# Bot Owner Configuration
OWNER_NUMBER=923001234567
OWNER_NAME=Marco Malik
BOT_NAME=MARCO MALIK MD
PREFIX=.

# Session
SESSION_ID=

# AI API Keys
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# WhatsApp Channel Link
CHANNEL_LINK=https://whatsapp.com/channel/your_channel_here

# Pairing Website
PAIR_WEBSITE=https://your-pairing-site.com

# MongoDB (optional - for persistent data)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/marco-malik

# Port (Railway/Render/Heroku)
PORT=3000

# Removebg API Key (for background removal)
REMOVEBG_API_KEY=your_removebg_api_key

# AntiDelete
ANTI_DELETE=true

# Auto Features
AUTO_READ=false
AUTO_REACT=true
REACT_MODE=random
AUTO_STATUS_VIEW=true
AUTO_STATUS_REPLY=true
STATUS_REPLY_MESSAGE=Seen Your Status 👀 By Marco Malik

# Bot Mode
BOT_MODE=public
